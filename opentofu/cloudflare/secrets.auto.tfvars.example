# Local-only sensitive + identifying values.
# Copy to `secrets.auto.tfvars` and fill real values.
# Never commit `secrets.auto.tfvars`.

cloudflare_api_token  = "<cloudflare-api-token>"
cloudflare_account_id = "<cloudflare-account-id>"
cloudflare_zone_id    = "<cloudflare-zone-id>"

edge_record_target    = "<edge-dns-target>"
origin_record_content = "<origin-ip-or-hostname>"

admin_email = "<admin-email-address>"

# Optional IdP values:
# idp_name          = "Pocket ID"
# idp_client_id     = "<client-id>"
# idp_client_secret = "<client-secret>"
# idp_auth_url      = "https://id.example.com/authorize"
# idp_token_url     = "https://id.example.com/token"
# idp_certs_url     = "https://id.example.com/.well-known/jwks.json"
