#compdef repo-sync

_repo_sync() {
  local context state state_descr line
  typeset -A opt_args

  local -a commands
  commands=(
    'init:initialize or clone project-state repo'
    'bootstrap:initialize state repo and config'
    'add:add and manage one repository'
    'track:alias for add --path <path> --existing'
    'sync:sync all configured repositories'
    'scan:discover local repositories into config'
    'state:state repository operations'
  )

  if (( CURRENT == 2 )); then
    _describe 'command' commands
    return
  fi

  case "$words[2]" in
    add)
      _arguments \
        '--push[push state commit]' \
        '--path[target repository path]:path:_files' \
        '--existing[do not clone; use existing git repository]' \
        '--key[custom non-github key]' \
        '--ignore-path[ignore state path from default mapping]:path:_files' \
        '1:repository:->repo'
      if [[ "$state" == "repo" ]]; then
        local -a repos
        repos=("${(@f)$(repo-sync __complete-repo "$PREFIX" 2>/dev/null)}")
        _describe 'repository' repos
      fi
      ;;
    track)
      _arguments \
        '--push[push state commit]' \
        '--key[custom non-github key]' \
        '--ignore-path[ignore state path from default mapping]:path:_files' \
        '1:path:_files' \
        '2:repository:->repo'
      if [[ "$state" == "repo" ]]; then
        local -a repos
        repos=("${(@f)$(repo-sync __complete-repo "$PREFIX" 2>/dev/null)}")
        _describe 'repository' repos
      fi
      ;;
    init|bootstrap|sync|scan)
      _arguments '--push[push state commit]'
      ;;
    state)
      if (( CURRENT == 3 )); then
        _describe 'state command' \
          'pull:pull latest state repo' \
          'add:add repo path to state mappings' \
          'commit:commit state changes' \
          'push:push state repo'
        return
      fi
      case "$words[3]" in
        add)
          _arguments \
            '--repo[target repository remote owner/repo or key]:repository:->repo' \
            '--repo-key[target repository key]:key:' \
            '--push[push state commit]' \
            '1:path:_files'
          if [[ "$state" == "repo" ]]; then
            local -a repos
            repos=("${(@f)$(repo-sync __complete-repo "$PREFIX" 2>/dev/null)}")
            _describe 'repository' repos
          fi
          ;;
        commit)
          _arguments \
            '--repo[repository remote owner/repo or key]:repository:->repo' \
            '--repo-key[repository key]:key:' \
            '--code-sha[code commit SHA]' \
            '--push[push state commit]'
          if [[ "$state" == "repo" ]]; then
            local -a repos
            repos=("${(@f)$(repo-sync __complete-repo "$PREFIX" 2>/dev/null)}")
            _describe 'repository' repos
          fi
          ;;
      esac
      ;;
  esac
}

_repo_sync "$@"
