{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "automerge": false,
  "schedule": [
    "before 6am on monday"
  ],
  "enabledManagers": [
    "nix",
    "github-actions"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "nix"
      ],
      "groupName": "nix flake inputs"
    }
  ]
}
